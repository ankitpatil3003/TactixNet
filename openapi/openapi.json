  "components": {
    "schemas": {
      "CreateSquadFromScenarioRequest": {
        "properties": {
          "scenario": {
            "type": "string",
            "minLength": 1,
            "title": "Scenario",
            "description": "Scenario file name without .yaml"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "scenario"
        ],
        "title": "CreateSquadFromScenarioRequest"
      },
      "CreateSquadRequest": {
        "properties": {
          "agent_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Agent Ids"
          },
          "objective_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Objective Ref"
          },
          "scenario": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "agent_ids"
        ],
        "title": "CreateSquadRequest"
      },
      "DoctrineUpdate": {
        "properties": {
          "squad_id": {
            "type": "string",
            "title": "Squad Id"
          },
          "role_weights": {
            "additionalProperties": {
              "type": "number"
            },
            "propertyNames": {
              "$ref": "#/components/schemas/RoleEnum"
            },
            "type": "object",
            "title": "Role Weights"
          },
          "priority_objective": {
            "type": "string",
            "title": "Priority Objective"
          },
          "fallback_plan": {
            "type": "string",
            "title": "Fallback Plan",
            "default": ""
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "squad_id",
          "role_weights",
          "priority_objective"
        ],
        "title": "DoctrineUpdate"
      },
      "GuardConfigRequest": {
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "title": "Id"
          },
          "position": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "maxItems": 2,
            "minItems": 2,
            "title": "Position"
          },
          "patrol": {
            "anyOf": [
              {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "type": "array"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Patrol"
          },
          "vision_range": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Vision Range"
          },
          "vision_angle_deg": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 360.0,
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Vision Angle Deg"
          },
          "patrol_speed": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Patrol Speed"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "position"
        ],
        "title": "GuardConfigRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RoleAward": {
        "properties": {
          "agent_id": {
            "type": "string",
            "title": "Agent Id"
          },
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "role": {
            "$ref": "#/components/schemas/RoleEnum"
          },
          "utility": {
            "type": "number",
            "title": "Utility"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "agent_id",
          "task_id",
          "role",
          "utility"
        ],
        "title": "RoleAward"
      },
      "RoleEnum": {
        "type": "string",
        "enum": [
          "flank",
          "distract",
          "stealth-cover",
          "overwatch",
          "breach"
        ],
        "title": "RoleEnum"
      },
      "SquadDirective": {
        "properties": {
          "squad_id": {
            "type": "string",
            "title": "Squad Id"
          },
          "directive_seq": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Directive Seq"
          },
          "tick": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Tick"
          },
          "awards": {
            "items": {
              "$ref": "#/components/schemas/RoleAward"
            },
            "type": "array",
            "title": "Awards"
          },
          "objective_ref": {
            "type": "string",
            "title": "Objective Ref"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "squad_id",
          "directive_seq",
          "tick",
          "awards",
          "objective_ref"
        ],
        "title": "SquadDirective"
      },
      "SquadListResponse": {
        "properties": {
          "squads": {
            "items": {
              "$ref": "#/components/schemas/SquadSummaryResponse"
            },
            "type": "array",
            "title": "Squads"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "squads",
          "total"
        ],
        "title": "SquadListResponse"
      },
      "SquadStateResponse": {
        "properties": {
          "squad_id": {
            "type": "string",
            "title": "Squad Id"
          },
          "agent_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Agent Ids"
          },
          "tick": {
            "type": "integer",
            "title": "Tick"
          },
          "doctrine": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DoctrineUpdate"
              },
              {
                "type": "null"
              }
            ]
          },
          "last_directive": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SquadDirective"
              },
              {
                "type": "null"
              }
            ]
          },
          "objective_ref": {
            "type": "string",
            "title": "Objective Ref"
          },
          "scenario": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "squad_id",
          "agent_ids",
          "tick",
          "doctrine",
          "last_directive",
          "objective_ref"
        ],
        "title": "SquadStateResponse"
      },
      "SquadSummaryResponse": {
        "properties": {
          "squad_id": {
            "type": "string",
            "title": "Squad Id"
          },
          "agent_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Agent Ids"
          },
          "tick": {
            "type": "integer",
            "title": "Tick"
          },
          "objective_ref": {
            "type": "string",
            "title": "Objective Ref"
          },
          "has_doctrine": {
            "type": "boolean",
            "title": "Has Doctrine"
          },
          "scenario_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario Name"
          },
          "guard_count": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Guard Count"
          },
          "simulation": {
            "type": "object",
            "title": "Simulation"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "squad_id",
          "agent_ids",
          "tick",
          "objective_ref",
          "has_doctrine",
          "simulation"
        ],
        "title": "SquadSummaryResponse"
      },
      "StartSimulationRequest": {
        "properties": {
          "scenario": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario",
            "description": "Scenario name; defaults to squad metadata if attached at creation"
          },
          "ticks": {
            "type": "integer",
            "maximum": 10000.0,
            "minimum": 1.0,
            "title": "Ticks",
            "default": 300
          },
          "hz": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 60.0,
                "exclusiveMinimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Hz"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "StartSimulationRequest"
      },
      "UpdateSquadScenarioRequest": {
        "properties": {
          "guards": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/GuardConfigRequest"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Guards"
          },
          "objective_position": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array",
                "maxItems": 2,
                "minItems": 2
              },
              {
                "type": "null"
              }
            ],
            "title": "Objective Position"
          },
          "grid_size": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 4.0
              },
              {
                "type": "null"
